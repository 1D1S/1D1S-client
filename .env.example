# ===== API (set by environment) =====
# local/dev example
NEXT_PUBLIC_ODOS_API_URL=https://your-api.example.com/
NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_NAME=devAccessToken
NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_NAME=devRefreshToken
# image host example (if image objects are stored separately)
# NEXT_PUBLIC_ODOS_IMAGE_URL=https://your-image-bucket.example.com/

# production example (replace in production env)
# NEXT_PUBLIC_ODOS_API_URL=https://your-production-api.example.com/
# NEXT_PUBLIC_ACCESS_TOKEN_COOKIE_NAME=accessToken
# NEXT_PUBLIC_REFRESH_TOKEN_COOKIE_NAME=refreshToken
